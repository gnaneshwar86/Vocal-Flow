{
  "name": "vocalflow-win",
  "version": "1.0.0",
  "description": "Voice typing system tray application",
  "author": "VocalFlow Team",
  "main": "dist/main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "tsc",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.vocalflow.app",
    "productName": "VocalFlow",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/renderer/settings.html",
      "src/renderer/styles.css",
      "config/**/*",
      "assets/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "@deepgram/sdk": "^3.0.0",
    "groq-sdk": "^0.3.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.10",
    "electron": "^29.1.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.3.3"
  }
}
